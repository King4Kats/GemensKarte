# dependencies
node_modules/
.pnpm-store/

# build output
dist/
build/
*.tsbuildinfo

# env
.env
.env.local
.env.*.local

# data dumps (RNA files are large — keep out of git)
# Le .gz est trop volumineux pour le dépôt (limite GitHub 100 Mo/fichier) :
# il est publié en Release asset (tag rna-latest) par le workflow fetch-rna,
# et récupéré par scripts/get-rna.sh. Voir aussi data/rna/rna_occitanie plus bas.
data/rna/*.csv
data/rna/*.zip
data/rna/*.gz
!data/rna/.gitkeep

# logs / os
*.log
.DS_Store
coverage/

# pipeline d'enrichissement (Python) — garder les scripts, exclure le reste
pipeline/.venv/
pipeline/_*.py
pipeline/_*.log
pipeline/_*.txt
pipeline/*.bak
__pycache__/
*.pyc

# secret local du pipeline (mot de passe DB)
.dbpass
pipeline/.dbpass
data/rna/rna_occitanie.csv.gz
