{
  "name": "@gemenskarte/api",
  "version": "0.1.0",
  "private": true,
  "description": "API GemensKarte (NestJS + PostGIS + Meilisearch)",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "db:migrate": "ts-node -T src/db/migrate.ts",
    "db:seed": "ts-node -T src/db/seed.ts",
    "search:reindex": "ts-node -T src/search/reindex.ts",
    "import:rna": "ts-node -T src/import/rna/cli.ts",
    "regeocode:missing": "ts-node -T src/import/rna/regeocode-missing.ts"
  },
  "dependencies": {
    "@gemenskarte/shared": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "meilisearch": "^0.47.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1",
    "nodemailer": "^6.9.14"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3",
    "@types/nodemailer": "^6.4.14"
  }
}